{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "projectSettings": {
    "sourceFilesOutsideRootDirectory": false
  },
  "env": {
    "NOTION_API_KEY": "@notion-api-key",
    "NOTION_BLOG_DATABASE_ID": "@notion-blog-database-id",
    "NEXT_PUBLIC_SITE_URL": "@next-public-site-url"
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=43200, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": [],
  "cleanUrls": true
}
